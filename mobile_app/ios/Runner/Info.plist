<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Info.plist – PathSathi (iOS)
  Declares background modes and usage descriptions required for passive
  trip tracking on iOS 16+.
-->
<plist version="1.0">
<dict>
	<!-- ── App Identity ───────────────────────────────────────────────── -->
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>PathSathi</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>path_sathi</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>

	<!-- ── Background Execution ──────────────────────────────────────── -->
	<!--
	  "location"       – Allows the app to receive location updates in the
	                     background (required for passive trip tracking).
	  "fetch"          – Enables background fetch for periodic sync.
	  "remote-notification" – Allows FCM to wake the app for Smart Nudge.
	  "processing"     – Allows BGTaskScheduler tasks (iOS 13+).
	-->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>fetch</string>
		<string>remote-notification</string>
		<string>processing</string>
	</array>

	<!-- ── Location Usage Descriptions ──────────────────────────────── -->
	<!--
	  iOS requires a human-readable justification for each location
	  permission tier. These strings appear in the OS permission dialogs.
	-->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>PathSathi tracks your trips in the background to automatically log your travel activity for the NATPAC mobility survey. Your precise location is only recorded while you are moving.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>PathSathi needs "Always" location access to detect trip starts and ends even when the app is in the background.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>PathSathi uses your location to record trip breadcrumbs while you travel.</string>

	<!-- ── Motion & Activity Usage Description ───────────────────────── -->
	<key>NSMotionUsageDescription</key>
	<string>PathSathi uses motion data to detect when you start a vehicle or bicycle trip, so GPS is only activated during active travel (saving battery).</string>

	<!-- ── Push Notifications (FCM) ──────────────────────────────────── -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<false/>

	<!-- ── UI ─────────────────────────────────────────────────────────── -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>

	<!-- Flutter embedding -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
</dict>
</plist>
