# VahiNav Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.

# PostgreSQL connection settings (matches docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vahinav_db
DB_USER=postgres
DB_PASSWORD=1234

# HTTP port the Express server listens on
PORT=8000

# Path to the Firebase service account key JSON file
# (this variable holds the FILE PATH to the JSON key, not the key content itself)
FIREBASE_SERVICE_ACCOUNT_KEY=<path-to-firebase-key.json>

# Firebase project ID (from Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your-firebase-project

# JSON Web Token secret — use a long random string in production
JWT_SECRET=your-secret-key

# Runtime environment: development | production | test
NODE_ENV=development
